# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Redis Configuration
redis_host=localhost

# Application Environment
# Options: development, staging, production
ENVIRONMENT=development

# ChromaDB Configuration
# Use ChromaDB server (HttpClient) instead of persistent client
# Automatically enabled for staging/production environments
USE_CHROMA_SERVER=false

# ChromaDB server connection details (for staging/production)
CHROMA_HOST=localhost
CHROMA_PORT=8000


IS_MAIN_SERVER=true # for main production server, false for other instances
SYNC_API_KEY=somelongrandomsecretkey12345
MAIN_SERVER_URL=https://vandalizer.nkn.uidaho.edu # for instances other than the main server
