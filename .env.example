# ============================================================================
# Vandalizer — Root Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================================

# --- LLM ---
# Required. Your OpenAI-compatible API key.
OPENAI_API_KEY=your_openai_api_key_here

# Optional. Custom LLM endpoint (OpenAI-compatible). Leave empty to use OpenAI directly.
INSIGHT_ENDPOINT=

# --- Infrastructure ---
redis_host=localhost

# --- Application ---
# Options: development, staging, production
ENVIRONMENT=development

# --- ChromaDB ---
# Use ChromaDB server (HttpClient) instead of persistent client.
# Automatically enabled for staging/production environments.
USE_CHROMA_SERVER=false

# ChromaDB server connection details (for staging/production)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMADB_PERSIST_DIR=../app/static/db

# --- M365 Integration (Graph API) ---
# Fernet key for encrypting Graph API tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GRAPH_TOKEN_KEY=

# Public HTTPS URL where Graph sends webhook notifications.
# Must be reachable from the internet (e.g. via ngrok in development).
GRAPH_NOTIFICATION_URL=https://your-domain.com/office/webhooks/graph

# Secret string echoed back by Graph in webhook payloads for validation.
GRAPH_CLIENT_STATE_SECRET=change-me-to-a-random-secret

# Base URL used in Teams Adaptive Card action links.
VANDALIZER_BASE_URL=https://your-domain.com
