# Frontend environment variables
# Copy this file to .env.local and customize as needed.

# Support link shown in the header (defaults to GitHub Issues)
# VITE_SUPPORT_URL=https://github.com/ui-insight/vandalizer/issues

# Sentry error reporting (leave unset to disable)
# VITE_SENTRY_DSN=https://<hash>@<org>.ingest.sentry.io/<project-id>
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=
